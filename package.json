{
  "name": "zujuan-scraper",
  "version": "1.0.0",
  "description": "组卷网爬虫工具 - 从zujuan.xkw.com爬取数学题目",
  "main": "dist/index.js",
  "bin": {
    "zujuan": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "NODE_OPTIONS='--no-deprecation' node ./dist/index.js",
    "dev": "ts-node src/index.ts",
    "postinstall": "node -e \"const fs=require('fs'),path=require('path'),os=require('os');const dir=path.join(os.homedir(),'.zujuan-scraper');if(!fs.existsSync(dir))fs.mkdirSync(dir,{recursive:true});['KNOWLEDGE_TREE_HIGH.txt','KNOWLEDGE_TREE_MIDDLE.txt'].forEach(f=>{const src=path.join(process.cwd(),f);if(fs.existsSync(src))fs.copyFileSync(src,path.join(dir,f));});\""
  },
  "keywords": [
    "crawler",
    "zujuan",
    "math",
    "education"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.8.0",
    "commander": "^12.0.0",
    "playwright": "^1.40.0",
    "terminal-image": "^4.2.0",
    "tesseract.js": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  }
}
